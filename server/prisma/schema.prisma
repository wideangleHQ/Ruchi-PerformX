  updated_at                 DateTime?          @default(now()) @db.Timestamptz(6)
  users                      users              @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_score_user")

  @@unique([user_id, month, year], map: "uq_user_month_year")
  @@index([year, month], map: "idx_scores_period")
  @@index([user_id], map: "idx_scores_user")
}

