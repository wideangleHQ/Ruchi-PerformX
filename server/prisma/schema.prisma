model Visitor {
  id                     String         @id @default(uuid()) @db.Uuid
  firstName              String         @db.VarChar(100)
  lastName               String?        @db.VarChar(100)
  fullName               String         @db.VarChar(255)
  email                  String?        @db.VarChar(255)
  mobileNumber           String?        @db.VarChar(20)
  companyName            String         @db.VarChar(255) @default("Unknown Company")
  address                String         @db.Text @default("N/A")
  status                 VisitorStatus  @default(ACTIVE)
  blacklistReason        String?
  blacklistedAt          DateTime?      @db.Timestamptz(6)
  faceRecognitionConsent Boolean        @default(false)
  notes                  String?
  createdById            String         @db.Uuid
  updatedById            String?        @db.Uuid
  createdAt              DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime       @updatedAt @db.Timestamptz(6)
  deletedAt              DateTime?      @db.Timestamptz(6)
  visits                 Visit[]        @relation("VisitorVisits")
  images                 VisitorImage[] @relation("VisitorImages")
  createdBy              users          @relation("visitor_created_by", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedBy              users?         @relation("visitor_updated_by", fields: [updatedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([email], map: "idx_visitors_email")
  @@index([mobileNumber], map: "idx_visitors_mobile_number")
  @@index([status], map: "idx_visitors_status")
  @@index([deletedAt], map: "idx_visitors_deleted_at")
  @@map("visitors")
}

model Visit {
  id                   String         @id @default(uuid()) @db.Uuid
  visitorId            String         @db.Uuid
  branchId             String         @db.Uuid
  hostEmployeeId       String         @db.Uuid
  status               VisitStatus    @default(SCHEDULED)
  visitCode            String?        @unique @db.VarChar(50)
  appointmentReference String?        @db.VarChar(100)
  purpose              String         @db.VarChar(255)
  meetingDetails       String?
  scheduledAt          DateTime?      @db.Timestamptz(6)
  checkInTime          DateTime?      @db.Timestamptz(6)
  checkOutTime         DateTime?      @db.Timestamptz(6)
  qrPassIssuedAt       DateTime?      @db.Timestamptz(6)
  qrPassExpiresAt      DateTime?      @db.Timestamptz(6)
  faceVerifiedAt       DateTime?      @db.Timestamptz(6)
  faceMatchScore       Decimal?       @db.Decimal(5, 2)
  aadhaarVerifiedAt    DateTime?      @db.Timestamptz(6)
  createdById          String         @db.Uuid
  updatedById          String?        @db.Uuid
  createdAt            DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime       @updatedAt @db.Timestamptz(6)
  deletedAt            DateTime?      @db.Timestamptz(6)
  visitor              Visitor        @relation("VisitorVisits", fields: [visitorId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  hostEmployee         users          @relation("visit_host_employee", fields: [hostEmployeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy            users          @relation("visit_created_by", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedBy            users?         @relation("visit_updated_by", fields: [updatedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  images               VisitorImage[] @relation("VisitImages")

  @@index([branchId], map: "idx_visits_branch_id")
  @@index([status], map: "idx_visits_status")
  @@index([checkInTime], map: "idx_visits_check_in_time")
  @@index([visitorId], map: "idx_visits_visitor_id")
  @@index([deletedAt], map: "idx_visits_deleted_at")
  @@map("visits")
}

model VisitorImage {
  id                   String             @id @default(uuid()) @db.Uuid
  visitorId            String             @db.Uuid
  visitId              String?            @db.Uuid
  imageType            VisitorImageType   @default(PROFILE)
  imageSource          VisitorImageSource @default(UPLOADED)
  fileName             String?            @db.VarChar(255)
  fileUrl              String             @db.VarChar(500)
  storagePath          String?            @db.VarChar(500)
  mimeType             String?            @db.VarChar(100)
  fileSizeKb           Int?
  isPrimary            Boolean            @default(false)
  isFaceTemplate       Boolean            @default(false)
  faceEmbeddingVersion String?            @db.VarChar(50)
  faceMatchScore       Decimal?           @db.Decimal(5, 2)
  createdById          String             @db.Uuid
  updatedById          String?            @db.Uuid
  createdAt            DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime           @updatedAt @db.Timestamptz(6)
  deletedAt            DateTime?          @db.Timestamptz(6)
  visitor              Visitor            @relation("VisitorImages", fields: [visitorId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  visit                Visit?             @relation("VisitImages", fields: [visitId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  createdBy            users              @relation("visitor_image_created_by", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedBy            users?             @relation("visitor_image_updated_by", fields: [updatedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([visitorId], map: "idx_visitor_images_visitor_id")
  @@index([visitId], map: "idx_visitor_images_visit_id")
  @@index([imageType], map: "idx_visitor_images_image_type")
  @@index([deletedAt], map: "idx_visitor_images_deleted_at")
  @@map("visitor_images")
}
