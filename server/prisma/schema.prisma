model performance_scores {
  id                         String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                    String             @db.Uuid
  month                      Int
  year                       Int
  self_productivity_score    Decimal?           @default(0) @db.Decimal(5, 2)
  assigned_task_score        Decimal?           @default(0) @db.Decimal(5, 2)
  final_score                Decimal?           @default(0) @db.Decimal(5, 2)
