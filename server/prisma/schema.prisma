generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model audit_logs {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  action     String    @db.VarChar(255)
  entity     String    @db.VarChar(100)
  entity_id  String    @db.Uuid
  old_value  String?
  new_value  String?
  ip_address String?   @db.VarChar(100)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_audit_user")

  @@index([entity, entity_id], map: "idx_audit_entity")
  @@index([user_id], map: "idx_audit_user")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model departments {
  id                                                      String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                                                    String                  @unique @db.VarChar(100)
  description                                             String?
  sort_order                                              Int                     @default(999)
  is_active                                               Boolean                 @default(true)
  created_at                                              DateTime                @default(now()) @db.Timestamptz(6)
  updated_at                                              DateTime                @default(now()) @db.Timestamptz(6)
  registration_requests                                   registration_requests[]
  task_transfers_task_transfers_from_dept_idTodepartments task_transfers[]        @relation("task_transfers_from_dept_idTodepartments")
  task_transfers_task_transfers_to_dept_idTodepartments   task_transfers[]        @relation("task_transfers_to_dept_idTodepartments")
  tasks                                                   tasks[]
  task_requests                                           task_requests[]
  users                                                   users[]
  hod_departments                                         hod_departments[]
  task_departments                                        task_departments[]
  assistant_departments                                   assistant_departments[]
  self_actions                                            self_actions[]
}

model hod_departments {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
