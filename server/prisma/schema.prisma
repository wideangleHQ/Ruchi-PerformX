  updated_at                                           DateTime?               @default(now()) @db.Timestamptz(6)
  deleted_at                                           DateTime?               @db.Timestamptz(6)
  email_verified_at                                    DateTime?               @db.Timestamptz(6)
  last_login_at                                        DateTime?               @db.Timestamptz(6)
  must_change_password                                 Boolean?                @default(false)
  is_email_verified                                    Boolean?                @default(false)
  pending_approval                                     Boolean?                @default(false)
  audit_logs                                           audit_logs[]
  incentives_incentives_approved_by_idTousers          incentives[]            @relation("incentives_approved_by_idTousers")
  incentives_incentives_employee_idTousers             incentives[]            @relation("incentives_employee_idTousers")
  notifications                                        notifications[]
  performance_scores                                   performance_scores[]
  registration_requests                                registration_requests[]
  self_actions                                         self_actions[]
  self_action_comments                                 self_action_comments[]
  self_action_logs                                     self_action_logs[]
  visitor_created_by                                   Visitor[]               @relation("visitor_created_by")
  visitor_updated_by                                   Visitor[]               @relation("visitor_updated_by")
  visit_host_employee                                  Visit[]                 @relation("visit_host_employee")
  visit_created_by                                     Visit[]                 @relation("visit_created_by")
  visit_updated_by                                     Visit[]                 @relation("visit_updated_by")
  visitor_image_created_by                             VisitorImage[]          @relation("visitor_image_created_by")
  visitor_image_updated_by                             VisitorImage[]          @relation("visitor_image_updated_by")
  task_requests_current_assignee                       task_requests[]         @relation("task_request_current_assignee")
  task_requests_requested_assignee                     task_requests[]         @relation("task_request_requested_assignee")
  task_attachments                                     task_attachments[]
  task_comments                                        task_comments[]
  task_escalations                                     task_escalations[]
  task_requests_task_requests_reviewed_by_idTousers    task_requests[]         @relation("task_requests_reviewed_by_idTousers")
  task_requests_task_requests_requested_by_idTousers   task_requests[]         @relation("task_requests_requested_by_idTousers")
  task_status_logs                                     task_status_logs[]
  task_transfers_task_transfers_initiated_by_idTousers task_transfers[]        @relation("task_transfers_initiated_by_idTousers")
  task_transfers_task_transfers_received_by_idTousers  task_transfers[]        @relation("task_transfers_received_by_idTousers")
  tasks_tasks_assigned_by_idTousers                    tasks[]                 @relation("tasks_assigned_by_idTousers")
  tasks_tasks_assigned_to_idTousers                    tasks[]                 @relation("tasks_assigned_to_idTousers")
  tasks_tasks_deleted_by_idTousers                     tasks[]                 @relation("tasks_deleted_by_idTousers")
  departments                                          departments?            @relation(fields: [department_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_department")
  password_reset_requests                              PasswordResetRequest[]
  hod_departments                                      hod_departments[]
  assistant_departments                                assistant_departments[]
